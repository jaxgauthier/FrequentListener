# Copy to .env and adjust. Flask loads .env when you run run.py

FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-for-local-dev

# Optional: bind address (default :: works for localhost + 127.0.0.1 on macOS)
# HOST=127.0.0.1

# Optional: Spotify search on admin (leave blank to disable search)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Optional: use Postgres instead of SQLite (not needed for local default)
# DATABASE_URL=postgresql://...
